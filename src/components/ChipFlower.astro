<!-- Rosette for the Digital Designer chip: 8 crimson petals, gold centre -->
<svg class="chip-icon block mx-auto w-24 h-24" viewBox="0 0 100 100" aria-hidden="true">
  <defs>
    <path id="fp" d="M0,0 C-7,-11 -7,-27 0,-38 C7,-27 7,-11 0,0 Z"/>
  </defs>
  <g transform="translate(50,50)">
    <g fill="#e0272d" stroke="#0e0c08" stroke-width="1.2">
      <use href="#fp" transform="rotate(0)"/>
      <use href="#fp" transform="rotate(45)"/>
      <use href="#fp" transform="rotate(90)"/>
      <use href="#fp" transform="rotate(135)"/>
      <use href="#fp" transform="rotate(180)"/>
      <use href="#fp" transform="rotate(225)"/>
      <use href="#fp" transform="rotate(270)"/>
      <use href="#fp" transform="rotate(315)"/>
    </g>
    <!-- Petal veins -->
    <g stroke="#0e0c08" stroke-width=".8" opacity=".7">
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(0)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(45)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(90)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(135)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(180)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(225)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(270)"/>
      <line x1="0" y1="0" x2="0" y2="-32" transform="rotate(315)"/>
    </g>
    <circle r="11" fill="#f0b31c" stroke="#c98f0d" stroke-width="1.5"/>
    <circle r="3.5" fill="#c98f0d"/>
  </g>
</svg>
