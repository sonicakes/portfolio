---
// Golden Khokhloma inversion: the single gold surface on the page.
// Closes the page like turning the spoon over — black → black → black → gold.
// Must remain singular; a second gold section would destroy the effect (§3.9).
import Spoons from './Spoons.astro';
---

<section id="contact" class="rise max-w-265 mx-auto px-6 py-18">
  <div class="relative text-center rounded bg-[linear-gradient(165deg,#f4bc27_0%,#e8a70f_55%,#cf920c_100%)] text-lacquer py-13 px-6 before:content-[''] before:absolute before:inset-2 before:rounded-xs before:border-[1.5px] before:border-lacquer/55 before:pointer-events-none">
    <Spoons />

    <h2 class="text-lacquer">Commission a piece</h2>
    <p class="max-w-[520px] mx-auto mb-6.5 text-[#4d3c08]">
      Available for front-end and full-stack work. If you want a site with an
      actual point of view — dark grounds and gold leaf optional — get in touch.
    </p>

    <div class="flex justify-center flex-wrap gap-7 font-mono text-[.85rem] tracking-[.08em]">
      <a href="mailto:hello@example.com" class="text-lacquer border-b-[1.5px] border-lacquer/45 pb-0.5 hover:text-crimson-deep hover:border-crimson-deep">Email</a>
      <a href="#" class="text-lacquer border-b-[1.5px] border-lacquer/45 pb-0.5 hover:text-crimson-deep hover:border-crimson-deep">GitHub</a>
      <a href="#" class="text-lacquer border-b-[1.5px] border-lacquer/45 pb-0.5 hover:text-crimson-deep hover:border-crimson-deep">LinkedIn</a>
      <a href="#" class="text-lacquer border-b-[1.5px] border-lacquer/45 pb-0.5 hover:text-crimson-deep hover:border-crimson-deep">Letterboxd</a>
    </div>
  </div>
</section>
