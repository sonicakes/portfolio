---
// Golden Khokhloma inversion: the single gold surface on the page.
// Closes the page like turning the spoon over — black → black → black → gold.
// Must remain singular; a second gold section would destroy the effect (§3.9).
import Spoons from './Spoons.astro';
---

<section id="contact" class="wrap rise">
  <div class="contact">
    <Spoons />

    <h2>Commission a piece</h2>
    <p>
      Available for front-end and full-stack work. If you want a site with an
      actual point of view — dark grounds and gold leaf optional — get in touch.
    </p>

    <div class="contact-row">
      <a href="mailto:hello@example.com">Email</a>
      <a href="#">GitHub</a>
      <a href="#">LinkedIn</a>
      <a href="#">Letterboxd</a>
    </div>
  </div>
</section>

<style>
  /* Gold gradient inversion */
  .contact {
    text-align: center;
    border-radius: 4px;
    position: relative;
    background: linear-gradient(165deg, #f4bc27 0%, #e8a70f 55%, #cf920c 100%);
    color: var(--color-lacquer);
    padding: 52px 24px;
  }
  /* Black inner keyline: 1.5px inset 8px */
  .contact::before {
    content: "";
    position: absolute;
    inset: 8px;
    border: 1.5px solid rgba(14,12,8,.55);
    border-radius: 2px;
    pointer-events: none;
  }

  .contact h2 { color: var(--color-lacquer); text-shadow: none; }

  .contact p {
    max-width: 520px;
    margin: 0 auto 26px;
    color: #4d3c08;
  }

  .contact-row {
    display: flex;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: .85rem;
    letter-spacing: .08em;
  }
  .contact-row a {
    color: var(--color-lacquer);
    border-bottom: 1.5px solid rgba(14,12,8,.45);
    padding-bottom: 2px;
  }
  .contact-row a:hover {
    color: var(--color-crimson-deep);
    border-color: var(--color-crimson-deep);
  }
</style>
