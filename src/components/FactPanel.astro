---
// Fact panel: --lacquer-soft card, hairline border, inner crimson keyline
// echoing the double-border convention of real Khokhloma lacquerware.
interface Fact {
  label: string;
  value: string;
}
interface Props {
  facts: Fact[];
}
const { facts } = Astro.props;
---

<aside class="relative rounded border border-hairline bg-lacquer-soft px-6.5 pt-6.5 pb-5.5 before:content-[''] before:absolute before:inset-1.5 before:rounded-xs before:border before:border-crimson/25 before:pointer-events-none">
  {facts.map(({ label, value }) => (
    <div class="flex justify-between gap-4 py-[9px] border-b border-dotted border-ink-cream/15 text-[.95rem] last:border-b-0">
      <b class="font-mono font-normal text-[.78rem] tracking-widest uppercase text-ink-dim whitespace-nowrap pt-0.5">{label}</b>
      <span class="text-right">{value}</span>
    </div>
  ))}
</aside>
