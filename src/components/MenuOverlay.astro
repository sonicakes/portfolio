---
// Full-screen menu overlay: vine draws itself on open, links stagger rise-in.
// Russian sublabels with lang="ru" per §2.2 bilingual rule.
// Escape closes; scroll locked while open; all ARIA on burger handled here.
---

<div class="menu-overlay fixed inset-0 z-110 bg-[rgba(14,12,8,.97)] flex items-center justify-center" id="menu" role="dialog" aria-label="Site menu">

  <!-- Left-edge vine: draws top-to-bottom on each open -->
  <svg class="menu-vine absolute left-[clamp(14px,6vw,80px)] top-0 h-full w-[60px]" viewBox="0 0 60 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <path class="mv" pathLength="1"
      d="M30,-10 C10,90 50,170 30,270 C10,370 50,450 30,550 C10,650 50,730 30,820"
      fill="none" stroke="#1e4a1f" stroke-width="4" stroke-linecap="round"/>
    <path class="mv" pathLength="1"
      d="M30,180 C44,172 54,178 54,190 C54,199 46,202 42,197"
      fill="none" stroke="#3f6d2a" stroke-width="2.5" stroke-linecap="round"/>
    <path class="mv" pathLength="1"
      d="M30,470 C16,462 6,468 6,480 C6,489 14,492 18,487"
      fill="none" stroke="#3f6d2a" stroke-width="2.5" stroke-linecap="round"/>
    <g class="mv-berry" fill="#e0272d">
      <circle cx="18" cy="320" r="6"/>
      <circle cx="30" cy="330" r="6"/>
      <circle cx="20" cy="340" r="6"/>
      <circle cx="42" cy="610" r="6"/>
      <circle cx="32" cy="622" r="6"/>
      <circle cx="44" cy="632" r="6"/>
    </g>
    <g class="mv-berry" fill="#f0b31c">
      <circle cx="42" cy="100" r="4"/>
      <circle cx="16" cy="700" r="4"/>
    </g>
  </svg>

  <button class="menu-close absolute top-[18px] right-5 w-12 h-12 bg-none rounded-full cursor-pointer flex items-center justify-center border border-crimson/35 transition-[border-color] duration-300 hover:border-crimson" aria-label="Close menu">
    <span class="mc-bar absolute w-5 h-0.5 rounded-sm bg-crimson"></span>
    <span class="mc-bar absolute w-5 h-0.5 rounded-sm bg-crimson"></span>
  </button>

  <ul class="menu-list list-none text-center">
    <li><a class="group inline-block px-2.5 py-3.5 font-display text-[clamp(1.7rem,5vw,2.5rem)] text-gold tracking-wider hover:text-crimson" href="#about">About<span class="ru block font-mono text-[.75rem] tracking-[.34em] uppercase text-ink-dim -mt-1 group-hover:text-crimson" lang="ru">О себе</span></a></li>
    <li><a class="group inline-block px-2.5 py-3.5 font-display text-[clamp(1.7rem,5vw,2.5rem)] text-gold tracking-wider hover:text-crimson" href="#work">Work<span class="ru block font-mono text-[.75rem] tracking-[.34em] uppercase text-ink-dim -mt-1 group-hover:text-crimson" lang="ru">Работы</span></a></li>
    <li><a class="group inline-block px-2.5 py-3.5 font-display text-[clamp(1.7rem,5vw,2.5rem)] text-gold tracking-wider hover:text-crimson" href="#craft">Craft<span class="ru block font-mono text-[.75rem] tracking-[.34em] uppercase text-ink-dim -mt-1 group-hover:text-crimson" lang="ru">Ремесло</span></a></li>
    <li><a class="group inline-block px-2.5 py-3.5 font-display text-[clamp(1.7rem,5vw,2.5rem)] text-gold tracking-wider hover:text-crimson" href="#story">Story<span class="ru block font-mono text-[.75rem] tracking-[.34em] uppercase text-ink-dim -mt-1 group-hover:text-crimson" lang="ru">История</span></a></li>
    <li><a class="group inline-block px-2.5 py-3.5 font-display text-[clamp(1.7rem,5vw,2.5rem)] text-gold tracking-wider hover:text-crimson" href="#contact">Contact<span class="ru block font-mono text-[.75rem] tracking-[.34em] uppercase text-ink-dim -mt-1 group-hover:text-crimson" lang="ru">Связь</span></a></li>
  </ul>
</div>

<script>
  const burger  = document.querySelector<HTMLButtonElement>('.burger')!;
  const overlay = document.getElementById('menu')!;

  function setMenu(open: boolean) {
    overlay.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger.addEventListener('click', () => setMenu(!overlay.classList.contains('open')));
  const closeBtn = overlay.querySelector<HTMLButtonElement>('.menu-close')!;
  closeBtn.addEventListener('click', () => setMenu(false));
  overlay.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') setMenu(false); });
</script>

<style>
  .menu-overlay {
    opacity: 0;
    pointer-events: none;
    transition: opacity .4s ease;
  }
  .menu-overlay.open { opacity: 1; pointer-events: auto; }

  .mc-bar:nth-child(1) { transform: rotate(45deg); }
  .mc-bar:nth-child(2) { transform: rotate(-45deg); }

  /* Vine paths draw on open; reset when .open drops (dashoffset returns to 1 instantly) */
  .menu-overlay.open .menu-vine .mv {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw 1.4s ease-out forwards .1s;
  }
  .menu-overlay.open .menu-vine .mv-berry {
    opacity: 0;
    animation: bloom .5s ease forwards 1.2s;
  }

  /* Nav links: staggered rise-in */
  .menu-list li { opacity: 0; transform: translateY(14px); }
  .menu-overlay.open .menu-list li {
    animation: riseIn .55s ease forwards;
  }
  .menu-overlay.open .menu-list li:nth-child(1) { animation-delay: .25s; }
  .menu-overlay.open .menu-list li:nth-child(2) { animation-delay: .38s; }
  .menu-overlay.open .menu-list li:nth-child(3) { animation-delay: .51s; }
  .menu-overlay.open .menu-list li:nth-child(4) { animation-delay: .64s; }
  .menu-overlay.open .menu-list li:nth-child(5) { animation-delay: .77s; }
</style>
