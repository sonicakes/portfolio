---
import FlowerMark from './FlowerMark.astro';
import Burger from './Burger.astro';
---

<nav class="sticky top-0 z-[90] bg-[rgba(14,12,8,.92)] backdrop-blur-[6px] border-b border-hairline">
  <div class="flex items-center justify-between px-6 py-3 max-w-[1060px] mx-auto">
    <div class="flex items-center gap-3">
      <FlowerMark />
      <div class="flex flex-col leading-[1.1]">
        <span class="font-display text-xl text-gold tracking-[.06em]">Sonia</span>
        <span class="font-mono text-[.68rem] text-ink-dim tracking-[.18em] uppercase">Parker</span>
      </div>
    </div>

    <!-- Inline links: visible ≥1180px -->
    <div class="hidden min-[1180px]:flex gap-7 items-center font-mono text-[.82rem] tracking-[.08em] uppercase">
      <a href="#about" class="group flex gap-2 flex-col items-center leading-tight">About<span class="block text-[.58rem] tracking-[.16em] text-ink-dim normal-case -mt-0.5 group-hover:text-crimson" lang="ru">о себе</span></a>
      <a href="#work" class="group flex gap-2 flex-col items-center leading-tight">Work<span class="block text-[.58rem] tracking-[.16em] text-ink-dim normal-case -mt-0.5 group-hover:text-crimson" lang="ru">работы</span></a>
      <a href="#craft" class="group flex gap-2 flex-col items-center leading-tight">Craft<span class="block text-[.58rem] tracking-[.16em] text-ink-dim normal-case -mt-0.5 group-hover:text-crimson" lang="ru">ремесло</span></a>
      <a href="#story" class="group flex gap-2 flex-col items-center leading-tight">Story<span class="block text-[.58rem] tracking-[.16em] text-ink-dim normal-case -mt-0.5 group-hover:text-crimson" lang="ru">история</span></a>
      <a href="#contact" class="group flex gap-2 flex-col items-center leading-tight">Contact<span class="block text-[.58rem] tracking-[.16em] text-ink-dim normal-case -mt-0.5 group-hover:text-crimson" lang="ru">связь</span></a>
    </div>

    <Burger />
  </div>
</nav>
