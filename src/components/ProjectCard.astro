---
interface Props {
  title: string;
  kind: string;
  description: string;
  tags: string[];
}
const { title, kind, description, tags } = Astro.props;
---

<article class="relative flex flex-col rounded border border-hairline bg-[linear-gradient(135deg,rgba(255,255,255,.05)_0%,transparent_35%),linear-gradient(160deg,#181510_0%,#100d09_60%,#0a0806_100%)] px-6 pt-6.5 pb-5.5 shadow-[0_4px_12px_rgba(240,179,28,.1)] transition-[border-color,transform] duration-300 hover:border-gold hover:-translate-y-[3px] motion-reduce:transition-none before:content-[''] before:absolute before:inset-1.5 before:rounded-xs before:border before:border-crimson/25 before:pointer-events-none">
  <!-- Three CSS-only berry dots: brand echo, zero assets -->
  <div class="absolute top-3.5 right-3.5 flex gap-[5px]" aria-hidden="true">
    <i class="relative block w-2 h-2 rounded-full bg-crimson after:content-[''] after:absolute after:inset-[2.5px] after:rounded-full after:bg-crimson-deep"></i>
    <i class="relative block w-2 h-2 rounded-full bg-crimson after:content-[''] after:absolute after:inset-[2.5px] after:rounded-full after:bg-crimson-deep"></i>
    <i class="relative block w-2 h-2 rounded-full bg-crimson after:content-[''] after:absolute after:inset-[2.5px] after:rounded-full after:bg-crimson-deep"></i>
  </div>

  <h3 class="font-display font-normal text-gold text-[1.18rem] tracking-[.04em] mb-1 pr-11">{title}</h3>
  <p class="font-mono text-[.72rem] tracking-[.16em] uppercase text-crimson mb-3.5">{kind}</p>
  <p class="text-[.95rem] text-ink-cream flex-1">{description}</p>

  <div class="flex flex-wrap gap-[7px] mt-4.5">
    {tags.map(tag => <i class="not-italic font-mono text-[.7rem] tracking-wider text-green-vine border border-green-vine/55 px-[9px] py-[3px] rounded-xs">{tag}</i>)}
  </div>
</article>
