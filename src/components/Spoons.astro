---
interface Props {
  variant?: 'light' | 'dark'; // light = gold panel (black bowls); dark = hero (gold bowls)
}
const { variant = 'light' } = Astro.props;
const bowl   = variant === 'dark' ? '#f0b31c' : '#0e0c08';
const stripe = variant === 'dark' ? '#c98f0d' : '#f0b31c';
const handle = variant === 'dark' ? '#f0b31c' : '#0e0c08';
---

<!-- Crossed spoons: contact panel crown (light) or hero ornament (dark) -->
<svg class={`spoons spoons--${variant}`} viewBox="0 0 120 96" aria-hidden="true">
  <g transform="rotate(-22 60 48)">
    <ellipse cx="60" cy="26" rx="17" ry="19" fill={bowl}/>
    <g fill="#e0272d">
      <circle cx="60"   cy="18" r="3.4"/>
      <circle cx="66.5" cy="22" r="3.4"/>
      <circle cx="66.5" cy="30" r="3.4"/>
      <circle cx="60"   cy="34" r="3.4"/>
      <circle cx="53.5" cy="30" r="3.4"/>
      <circle cx="53.5" cy="22" r="3.4"/>
    </g>
    <circle cx="60" cy="26" r="3.2" fill={stripe}/>
    <rect x="57.5" y="45" width="5"   height="42" rx="2.5" fill={handle}/>
    <rect x="58.7" y="52" width="2.6" height="24" rx="1.3" fill={stripe}/>
  </g>
  <g transform="rotate(22 60 48)">
    <ellipse cx="60" cy="26" rx="17" ry="19" fill={bowl}/>
    <g fill="#e0272d">
      <circle cx="60"   cy="18" r="3.4"/>
      <circle cx="66.5" cy="22" r="3.4"/>
      <circle cx="66.5" cy="30" r="3.4"/>
      <circle cx="60"   cy="34" r="3.4"/>
      <circle cx="53.5" cy="30" r="3.4"/>
      <circle cx="53.5" cy="22" r="3.4"/>
    </g>
    <circle cx="60" cy="26" r="3.2" fill={stripe}/>
    <rect x="57.5" y="45" width="5"   height="42" rx="2.5" fill={handle}/>
    <rect x="58.7" y="52" width="2.6" height="24" rx="1.3" fill={stripe}/>
  </g>
</svg>

<style>
  .spoons {
    display: block;
    margin: 0 auto 18px;
    width: 104px;
    height: auto;
  }
  .spoons--dark {
    width: 88px;
    margin-bottom: 4px;
    filter: drop-shadow(0 3px 10px rgba(0,0,0,.6));
    opacity: .92;
  }
</style>
