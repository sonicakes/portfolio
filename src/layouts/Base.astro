---
import Nav from '../components/Nav.astro';
import MenuOverlay from '../components/MenuOverlay.astro';
import SideVines from '../components/SideVines.astro';
import '../styles/theme.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title       = 'Sonia — Developer · Khokhloma Portfolio',
  description = 'Front-end & full-stack developer. TypeScript, Vue, React, C#. Portfolio painted in the black lacquer, crimson and gold of Khokhloma folk art.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <title>{title}</title>

  <!-- Google Fonts: Ruslan Display (display), PT Sans (body), PT Mono (utility) -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link
    href="https://fonts.googleapis.com/css2?family=Ruslan+Display&family=PT+Sans:wght@400;700&family=PT+Mono&display=swap"
    rel="stylesheet"
  />
</head>
<body class="bg-lacquer text-ink-cream font-body text-[17px] leading-[1.65] antialiased px-0 min-[820px]:px-[52px]">
  <SideVines />
  <Nav />
  <MenuOverlay />

  <slot />

  <footer class="text-center px-6 pt-8.5 pb-10.5 text-ink-dim font-mono text-[.75rem] tracking-[.12em] border-t border-hairline">
    <span lang="ru">Расписано вручную</span> · Ornament Art created in Adobe Illustrator by Author based on IRL Khokhloma spoon ·
    · © 2026 Sonia Parker
  </footer>
</body>
</html>
