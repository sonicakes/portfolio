---
import Base from '../layouts/Base.astro';
import Kustik from '../components/Kustik.astro';
import Divider from '../components/Divider.astro';
import ProjectCard from '../components/ProjectCard.astro';
import FactPanel from '../components/FactPanel.astro';
import ContactPanel from '../components/ContactPanel.astro';

const projects = [
  {
    title: 'Kino Royale',
    kind: 'Podcast platform',
    description:
      'Full production site for an independent film-criticism podcast: git-backed CMS, custom RSS feed endpoint, zero-egress audio delivery, and a bespoke design system with strict token rules.',
    tags: ['Next.js 15', 'TypeScript', 'Tailwind v4', 'Decap CMS', 'Cloudflare R2'],
  },
  {
    title: 'Royal Simulator',
    kind: 'Browser game',
    description:
      'A darkly comic choose-your-fate horror game with a large library of authored scenarios driven from a single JSON data file, styled after Polish film posters.',
    tags: ['React', 'Vite', 'TypeScript', 'Tailwind v4', 'Netlify'],
  },
  {
    title: 'Cinefile Blog',
    kind: 'Publication',
    description:
      'A film review publication built and operated end-to-end: custom domain and DNS, static delivery, and long-form criticism with proper Chicago-style citations.',
    tags: ['Static site', 'Netlify', 'Custom DNS', 'Editorial design'],
  },
];

const facts = [
  { label: 'Base',       value: 'Sydney, Australia' },
  { label: 'Experience', value: '6+ years professional' },
  { label: 'Cloud',      value: 'Azure certified (AZ-104)' },
  { label: 'Languages',  value: 'Russian · English · French · Spanish · Thai' },
  { label: 'Off-duty',   value: 'Film criticism, folk art, one Labrador' },
];

const craftColumns = [
  {
    heading: 'Front of house',
    items: [
      'TypeScript & modern JavaScript',
      'React & Next.js',
      'Vue.js',
      'Tailwind CSS & design tokens',
      'Accessible, responsive UI',
    ],
  },
  {
    heading: 'Back of house',
    items: [
      'C# / .NET',
      'Node.js',
      'PostgreSQL (Neon)',
      'Headless & git-backed CMS',
      'REST APIs & RSS pipelines',
    ],
  },
  {
    heading: 'Workshop',
    items: [
      'Azure — certified administrator',
      'AWS & Cloudflare',
      'Netlify CI/CD',
      'Database migrations',
      'Audio production tooling',
    ],
  },
];
---

<Base>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <header>
    <Kustik />
    <h1>Sonia</h1>
    <p class="hero-cyrillic" lang="ru">Соня</p>
    <p class="hero-role">Front-end &amp; Full-stack Developer</p>
    <p class="hero-line">
      Six-plus years building for the web — TypeScript, Vue, React and C# —
      painted here in the black lacquer, crimson and gold of Khokhloma,
      the folk art I grew up with and still make by hand.
    </p>
    <a class="hero-cta" href="#work">See the work</a>
  </header>

  <Divider phase="a" />

  <!-- ── About ─────────────────────────────────────────────────────────── -->
  <section id="about" class="wrap rise">
    <h2>About</h2>
    <p class="sub">The artisan behind the lacquer</p>
    <div class="about-grid">
      <div>
        <p>
          I'm a developer based in Sydney who treats interfaces the way Khokhloma
          masters treat wood: start with a dark, quiet ground, then apply ornament
          only where it earns its place. Most of my work lives in the JavaScript
          world — Vue and React on the front, Node and C# behind it — with a soft
          spot for design systems, strict tokens, and typography that carries a
          point of view.
        </p>
        <p>
          Outside client work I run an independent production label where I build
          everything myself end-to-end: a podcast platform on Next.js 15, a browser
          game in React, and a blog — my own three-panel folk triptych of code,
          film criticism and mischief.
        </p>
        <p>
          The artwork on this page is drawn from a piece I painted myself — a
          traditional spoon in the Kudrina style: black field, crimson rosette,
          gold leaves, rowan berries.
        </p>
      </div>
      <FactPanel facts={facts} />
    </div>
  </section>

  <Divider phase="b" />

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section id="work" class="wrap rise">
    <h2>Selected Work</h2>
    <p class="sub">Painted, fired, shipped</p>
    <div class="cards">
      {projects.map(p => (
        <ProjectCard
          title={p.title}
          kind={p.kind}
          description={p.description}
          tags={p.tags}
        />
      ))}
    </div>
  </section>

  <Divider phase="a" />

  <!-- ── Craft ─────────────────────────────────────────────────────────── -->
  <section id="craft" class="wrap rise">
    <h2>Craft</h2>
    <p class="sub">Tools of the trade</p>
    <div class="craft-grid">
      {craftColumns.map(col => (
        <div class="craft">
          <h3>{col.heading}</h3>
          <ul>
            {col.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Contact (golden inversion) ────────────────────────────────────── -->
  <ContactPanel />

</Base>

<!-- Section rise-in: IntersectionObserver, threshold .12, fires once per section -->
<script>
  const io = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.rise').forEach(el => io.observe(el));
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  header {
    text-align: center;
    padding: 56px 24px 30px;
    overflow: hidden;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    color: var(--color-gold);
    letter-spacing: .05em;
    margin-top: 18px;
    text-shadow: 0 0 26px rgba(240,179,28,.22);
  }

  .hero-cyrillic {
    font-family: var(--font-display);
    color: var(--color-crimson);
    font-size: clamp(1.15rem, 3vw, 1.6rem);
    letter-spacing: .42em;
    text-indent: .42em;
    margin-top: 6px;
  }

  .hero-role {
    font-family: var(--font-mono);
    color: var(--color-ink-dim);
    letter-spacing: .28em;
    text-transform: uppercase;
    font-size: .85rem;
    margin-top: 14px;
  }

  .hero-line {
    max-width: 560px;
    margin: 20px auto 0;
    color: var(--color-ink-dim);
    font-size: 1.02rem;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 30px;
    font-family: var(--font-mono);
    font-size: .85rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid var(--color-gold-deep);
    padding: 12px 30px;
    border-radius: 2px;
    transition: background .25s, color .25s, border-color .25s;
  }
  .hero-cta:hover {
    background: var(--color-crimson);
    border-color: var(--color-crimson);
    color: var(--color-lacquer);
  }

  /* ── About ────────────────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 44px;
    align-items: start;
  }
  @media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; } }
  .about-grid p + p { margin-top: 14px; }

  /* ── Work cards ───────────────────────────────────────────────────────── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 880px) { .cards { grid-template-columns: 1fr; } }

  /* ── Craft ────────────────────────────────────────────────────────────── */
  .craft-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  @media (max-width: 880px) { .craft-grid { grid-template-columns: 1fr; } }

  .craft { border-top: 2px solid var(--color-crimson); padding-top: 18px; }

  .craft h3 {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: .8rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 12px;
  }

  .craft ul { list-style: none; }
  .craft li {
    padding: 6px 0 6px 22px;
    position: relative;
    font-size: .96rem;
  }
  .craft li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 13px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-crimson);
  }
  .craft li:nth-child(even)::before { background: var(--color-gold); }
</style>
