---
import Base from '../layouts/Base.astro';
import Kustik from '../components/Kustik.astro';
import Spoons from '../components/Spoons.astro';
import ChipFlower from '../components/ChipFlower.astro';
import ChipBerry from '../components/ChipBerry.astro';
import Divider from '../components/Divider.astro';
import ProjectCard from '../components/ProjectCard.astro';
import FactPanel from '../components/FactPanel.astro';
import ContactPanel from '../components/ContactPanel.astro';

const projects = [
  {
    title: 'Kino Royale',
    kind: 'Podcast platform',
    description:
      'Full production site for an independent film-criticism podcast: git-backed CMS, custom RSS feed endpoint, zero-egress audio delivery, and a bespoke design system with strict token rules.',
    tags: ['Next.js 15', 'TypeScript', 'Tailwind v4', 'Decap CMS', 'Cloudflare R2'],
  },
  {
    title: 'Royal Simulator',
    kind: 'Browser game',
    description:
      'A darkly comic choose-your-fate horror game with a large library of authored scenarios driven from a single JSON data file, styled after Polish film posters.',
    tags: ['React', 'Vite', 'TypeScript', 'Tailwind v4', 'Netlify'],
  },
  {
    title: 'Cinefile Blog',
    kind: 'Publication',
    description:
      'A film review publication built and operated end-to-end: custom domain and DNS, static delivery, and long-form criticism with proper Chicago-style citations.',
    tags: ['Static site', 'Netlify', 'Custom DNS', 'Editorial design'],
  },
];

const facts = [
  { label: 'Base',       value: 'Sydney, Australia' },
  { label: 'Origins',    value: 'Russian-born, Australian-made.' },
  { label: 'Experience', value: '6+ years professional' },
  { label: 'Cloud',      value: 'Azure certified (AZ-104)' },
  { label: 'Languages',  value: 'Russian · English · French · Spanish' },
  { label: 'Off-duty',   value: 'Film criticism, folk art, one Labrador' },
];

const craftColumns = [
  {
    heading: 'Front of house',
    items: [
      'TypeScript & modern JavaScript',
      'React & Next.js',
      'Vue.js',
      'Tailwind CSS & design tokens',
      'Accessible, responsive UI',
    ],
  },
  {
    heading: 'Back of house',
    items: [
      'C# / .NET',
      'Node.js',
      'PostgreSQL (Neon)',
      'Headless & git-backed CMS',
      'REST APIs & RSS pipelines',
    ],
  },
  {
    heading: 'Workshop',
    items: [
      'Azure — certified administrator',
      'AWS & Cloudflare',
      'Netlify CI/CD',
      'Database migrations',
      'Audio production tooling',
    ],
  },
];
---

<Base>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <header class="text-center relative px-12 pb-11 bg-[radial-gradient(ellipse_70%_55%_at_50%_38%,rgba(240,179,28,.04)_0%,rgba(200,120,12,.02)_40%,transparent_70%),radial-gradient(ellipse_40%_30%_at_50%_22%,rgba(240,179,28,.03)_0%,transparent_100%)]">
    <Kustik />
    <h1 class="font-display font-normal text-[clamp(2.6rem,7vw,4.4rem)] text-gold tracking-wider leading-[1.05] text-shadow-[0_0_26px_rgba(240,179,28,.22)]">Sonia</h1>
    <p class="font-display text-[clamp(1.1rem,2.8vw,1.55rem)] text-ink-dim tracking-[.08em] -mt-1.5">Parker</p>

    <!-- Vine arrows: branch from name down to each role card -->
    <svg class="role-vines block w-[min(600px,100%)] h-22 mt-1.5 mx-auto overflow-visible" viewBox="0 0 580 88" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
      <!-- Left stem → Digital Designer -->
      <path class="rv-stem rv-stem--l" pathLength="1"
        d="M290,2 C270,18 230,30 185,46 C155,57 120,64 92,74"
        fill="none" stroke="rgba(30,74,31,.38)" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Centre stem → Front-End Dev -->
      <path class="rv-stem rv-stem--c" pathLength="1"
        d="M290,2 C294,22 286,48 290,74"
        fill="none" stroke="rgba(30,74,31,.38)" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Right stem → Content Creator -->
      <path class="rv-stem rv-stem--r" pathLength="1"
        d="M290,2 C310,18 350,30 395,46 C425,57 460,64 488,74"
        fill="none" stroke="rgba(30,74,31,.38)" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Curling side tendrils -->
      <path class="rv-tendril" pathLength="1"
        d="M185,46 C178,36 166,34 163,42 C161,48 167,53 174,49"
        fill="none" stroke="rgba(63,109,42,.3)" stroke-width="1.8" stroke-linecap="round"/>
      <path class="rv-tendril" pathLength="1"
        d="M395,46 C402,36 414,34 417,42 C419,48 413,53 406,49"
        fill="none" stroke="rgba(63,109,42,.3)" stroke-width="1.8" stroke-linecap="round"/>
      <!-- Berry tips at card entrances -->
      <g class="rv-berry">
        <circle cx="92"  cy="76" r="5.5" fill="#e0272d"/><circle cx="92"  cy="76" r="2" fill="#7c0f12"/>
        <circle cx="290" cy="76" r="5.5" fill="#e0272d"/><circle cx="290" cy="76" r="2" fill="#7c0f12"/>
        <circle cx="488" cy="76" r="5.5" fill="#e0272d"/><circle cx="488" cy="76" r="2" fill="#7c0f12"/>
      </g>
    </svg>

    <div class="hero-roles flex justify-center gap-7 flex-wrap mt-0 w-full">
      <div class="role-chip perspective-[900px] flex-1 min-w-35 max-w-60 h-60 cursor-pointer">
        <div class="chip-inner relative w-full h-full transform-3d">
          <div class="chip-front absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2.5 px-5 pt-5 pb-4.5 bg-lacquer-soft before:content-[''] before:absolute before:inset-1.75 before:rounded-xs before:border before:border-gold/14 before:pointer-events-none">
            <ChipFlower />
            <span class="font-display text-base tracking-wider text-gold">Digital Designer</span>
            <span class="chip-tap font-body text-[.72rem] tracking-[.04em] text-ink-dim opacity-70" aria-hidden="true">Tap to reveal</span>
          </div>
          <div class="chip-back absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2 px-5 pt-5 pb-4.5 transform-[rotateY(180deg)] bg-[linear-gradient(165deg,#f4bc27_0%,#e8a70f_55%,#cf920c_100%)] before:content-[''] before:absolute before:inset-2 before:rounded-xs before:border-[1.5px] before:border-lacquer/40 before:pointer-events-none">
            <span class="font-display text-base text-lacquer tracking-wider">Digital Designer</span>
            <p class="font-mono text-[.72rem] tracking-[.06em] text-[#4d3c08] leading-[1.7] text-center">UI/UX · Design systems<br/>Figma → production code</p>
            <a href="#work" class="mt-1.5 font-mono text-[.72rem] tracking-widest uppercase text-lacquer border border-lacquer/50 px-3.5 py-1.75 rounded-xs transition-[background,color] duration-200 hover:bg-lacquer hover:text-gold">See design work</a>
          </div>
        </div>
      </div>
      <div class="role-chip perspective-[900px] flex-1 min-w-35 max-w-60 h-60 cursor-pointer">
        <div class="chip-inner relative w-full h-full transform-3d">
          <div class="chip-front absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2.5 px-5 pt-5 pb-4.5 bg-lacquer-soft before:content-[''] before:absolute before:inset-1.75 before:rounded-xs before:border before:border-gold/14 before:pointer-events-none">
            <Spoons />
            <span class="font-display text-base tracking-wider text-gold">Front-End Dev</span>
            <span class="chip-tap font-body text-[.72rem] tracking-[.04em] text-ink-dim opacity-70" aria-hidden="true">Tap to reveal</span>
          </div>
          <div class="chip-back absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2 px-5 pt-5 pb-4.5 transform-[rotateY(180deg)] bg-[linear-gradient(165deg,#f4bc27_0%,#e8a70f_55%,#cf920c_100%)] before:content-[''] before:absolute before:inset-2 before:rounded-xs before:border-[1.5px] before:border-lacquer/40 before:pointer-events-none">
            <span class="font-display text-base text-lacquer tracking-wider">Front-End Dev</span>
            <p class="font-mono text-[.72rem] tracking-[.06em] text-[#4d3c08] leading-[1.7] text-center">Vue · React · TypeScript<br/>Tailwind · design tokens</p>
            <a href="#work" class="mt-1.5 font-mono text-[.72rem] tracking-widest uppercase text-lacquer border border-lacquer/50 px-3.5 py-1.75 rounded-xs transition-[background,color] duration-200 hover:bg-lacquer hover:text-gold">See dev projects</a>
          </div>
        </div>
      </div>
      <div class="role-chip perspective-[900px] flex-1 min-w-35 max-w-60 h-60 cursor-pointer">
        <div class="chip-inner relative w-full h-full transform-3d">
          <div class="chip-front absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2.5 px-5 pt-5 pb-4.5 bg-lacquer-soft before:content-[''] before:absolute before:inset-1.75 before:rounded-xs before:border before:border-gold/14 before:pointer-events-none">
            <ChipBerry />
            <span class="font-display text-base tracking-wider text-gold">Content Creator</span>
            <span class="chip-tap font-body text-[.72rem] tracking-[.04em] text-ink-dim opacity-70" aria-hidden="true">Tap to reveal</span>
          </div>
          <div class="chip-back absolute inset-0 rounded backface-hidden flex flex-col items-center justify-center gap-2 px-5 pt-5 pb-4.5 transform-[rotateY(180deg)] bg-[linear-gradient(165deg,#f4bc27_0%,#e8a70f_55%,#cf920c_100%)] before:content-[''] before:absolute before:inset-2 before:rounded-xs before:border-[1.5px] before:border-lacquer/40 before:pointer-events-none">
            <span class="font-display text-base text-lacquer tracking-wider">Content Creator</span>
            <p class="font-mono text-[.72rem] tracking-[.06em] text-[#4d3c08] leading-[1.7] text-center">Film criticism · Podcast<br/>Editorial · Production</p>
            <a href="#work" class="mt-1.5 font-mono text-[.72rem] tracking-widest uppercase text-lacquer border border-lacquer/50 px-3.5 py-1.75 rounded-xs transition-[background,color] duration-200 hover:bg-lacquer hover:text-gold">See content work</a>
          </div>
        </div>
      </div>
    </div>

    <a class="hero-cta inline-block mt-7.5 font-mono text-[.85rem] tracking-[.12em] uppercase text-lacquer bg-gold border border-gold-deep px-7.5 py-3 rounded-xs transition-[background,color,border-color] duration-250 hover:bg-transparent hover:border-gold-deep hover:text-gold" href="#work">See all work</a>
  </header>
  <!-- Spoon handle: flow element between bowl and divider -->
  <div class="w-1.5 h-9 mx-auto rounded-b bg-[linear-gradient(to_bottom,rgba(240,179,28,.55),rgba(240,179,28,.22))] shadow-[0_6px_16px_rgba(0,0,0,.4),0_2px_6px_rgba(0,0,0,.3)]" aria-hidden="true"></div>

  <Divider phase="a" />

  <!-- ── About ─────────────────────────────────────────────────────────── -->
  <section id="about" class="rise max-w-265 mx-auto px-6 py-18">
    <h2 class="font-display font-normal text-gold text-[clamp(1.5rem,3.6vw,2.1rem)] tracking-wider text-center mb-2">About</h2>
    <p class="sub text-center font-mono text-[.78rem] tracking-[.22em] uppercase text-ink-dim mb-11">The artisan behind the lacquer</p>
    <div class="about-grid grid grid-cols-[1.4fr_1fr] gap-11 items-start max-[760px]:grid-cols-1">
      <div>
        <p>
          <img src="/avatar.jpg" alt="Sonia Parker" class="avatar float-left w-50 h-50 rounded-full object-cover mt-1 mr-5.5 mb-3 ml-0 border-2 border-gold/45 shadow-[0_0_0_4px_rgba(240,179,28,.08),0_8px_24px_rgba(0,0,0,.5)] [shape-outside:circle(50%)] max-[760px]:float-none max-[760px]:block max-[760px]:mx-auto max-[760px]:mt-0 max-[760px]:mb-5" />
          <span class="capitalize font-bold">привет! (Privet! - Hello!) </span>I'm a Russian-Australian Designer, Developer & Content Creator based around Sydney, Australia.

           I treat interfaces the way Khokhloma
          masters treat wood: start with a dark, quiet ground, then apply ornament
          only where it earns its place. Most of my work lives at the front-end —
          Vue and React, but also the design decisions underneath: type scales,
          spacing systems, interaction states. What I find most interesting is the
          distance between a design file and a finished interface, and how much
          craft it takes to close it faithfully.
        </p>
        <p class="mt-3.5">
          Outside client work I run an independent production label where I build
          everything myself end-to-end: a podcast platform on Next.js 15, a browser
          game in React, and a blog — my own three-panel folk triptych of code,
          film criticism and mischief.
        </p>
        <p class="mt-3.5">
          The artwork on this page is drawn from a piece I painted myself — a
          traditional spoon in the Kudrina style: black field, crimson rosette,
          gold leaves, rowan berries.
        </p>
      </div>
      <FactPanel facts={facts} />
    </div>
  </section>

  <Divider phase="b" />

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section id="work" class="rise max-w-265 mx-auto px-6 py-18">
    <h2 class="font-display font-normal text-gold text-[clamp(1.5rem,3.6vw,2.1rem)] tracking-wider text-center mb-2">Selected Work</h2>
    <p class="sub text-center font-mono text-[.78rem] tracking-[.22em] uppercase text-ink-dim mb-11">Painted, fired, shipped</p>
    <div class="cards grid grid-cols-3 gap-5.5 max-[880px]:grid-cols-1">
      {projects.map(p => (
        <ProjectCard
          title={p.title}
          kind={p.kind}
          description={p.description}
          tags={p.tags}
        />
      ))}
    </div>
  </section>

  <Divider phase="a" />

  <!-- ── Craft ─────────────────────────────────────────────────────────── -->
  <section id="craft" class="rise max-w-265 mx-auto px-6 py-18">
    <h2 class="font-display font-normal text-gold text-[clamp(1.5rem,3.6vw,2.1rem)] tracking-wider text-center mb-2">Craft</h2>
    <p class="sub text-center font-mono text-[.78rem] tracking-[.22em] uppercase text-ink-dim mb-11">Tools of the trade</p>
    <div class="craft-grid grid grid-cols-3 gap-5.5 max-[880px]:grid-cols-1">
      {craftColumns.map(col => (
        <div class="craft border-t-2 border-crimson pt-4.5">
          <h3 class="font-mono font-normal text-[.8rem] tracking-[.2em] uppercase text-gold mb-3">{col.heading}</h3>
          <ul class="list-none">
            {col.items.map(item => <li class="craft-li py-1.5 pl-5.5 relative text-[.96rem]">{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <Divider phase="b" />

  <!-- ── Story ─────────────────────────────────────────────────────────── -->
  <section id="story" class="rise max-w-265 mx-auto px-6 py-18">
    <h2 class="font-display font-normal text-gold text-[clamp(1.5rem,3.6vw,2.1rem)] tracking-wider text-center mb-2">Khokhloma</h2>
    <p class="sub text-center font-mono text-[.78rem] tracking-[.22em] uppercase text-ink-dim mb-11">Folk art, rendered in code</p>
    <div class="story-grid grid grid-cols-[1fr_240px] gap-13 items-start max-[760px]:grid-cols-1">
      <div class="story-prose">
        <p>
          Khokhloma is a Russian folk painting tradition from the 17th century, originating
          in the forests of the Nizhny Novgorod region. Craftspeople decorated turned wooden
          objects — bowls, ladles, spoons — with a black lacquer ground, then applied
          ornament in red, gold, and green before firing in a kiln. Heat transformed silver
          tin powder into gold, producing the characteristic warm gleam of genuine Khokhloma
          lacquerware. The four colours — black, crimson, gold, green — have not changed
          in three centuries.
        </p>
        <p class="mt-4">
          The style used here is Kudrina — a variation built on movement rather than
          pattern. Where standard Khokhloma fills the ground with isolated berries and
          leaves, Kudrina composes a <em class="italic text-gold">kustik</em> (little bush): a central rosette
          anchoring spiralling vine tendrils, with rowan clusters appearing where the
          stems branch. It is a style with a strict painting order — vine framework first,
          then leaves, then the rosette, then the berries last. The SVG animation in the
          hero follows that exact sequence.
        </p>
        <p class="mt-4">
          The ornament on this site is drawn directly from a spoon I painted by hand.
          Every hex value in the colour system is sampled from that physical piece:
          the lacquer ground, the rosette crimson, the leaf gold, the vine green.
          The kustik SVG in the hero mirrors its composition — same stem geometry,
          same teardrop leaves, same twelve-berry clusters, same five rim dots.
          Building the site was, in a sense, painting the spoon again — this time
          in a text editor.
        </p>
      </div>

      <!-- Spoon figure: replace src with photo/scan when available (§8 open item) -->
      <figure class="spoon-fig relative text-center rounded border border-hairline bg-lacquer-soft px-5 pt-7 pb-5 max-[760px]:max-w-70 max-[760px]:mx-auto before:content-[''] before:absolute before:inset-1.5 before:rounded-xs before:border before:border-crimson/18 before:pointer-events-none">
        <div class="flex justify-center pt-4 pb-2" aria-hidden="true">
          <svg viewBox="0 0 120 200" width="80" opacity=".4">
            <ellipse cx="60" cy="42" rx="28" ry="32" fill="#0e0c08" stroke="#f0b31c" stroke-width="1.5"/>
            <g fill="#e0272d">
              <circle cx="60"   cy="30" r="5.5"/>
              <circle cx="70"   cy="37" r="5.5"/>
              <circle cx="70"   cy="49" r="5.5"/>
              <circle cx="60"   cy="56" r="5.5"/>
              <circle cx="50"   cy="49" r="5.5"/>
              <circle cx="50"   cy="37" r="5.5"/>
            </g>
            <circle cx="60" cy="43" r="5.2" fill="#f0b31c"/>
            <rect x="57" y="74" width="6" height="100" rx="3" fill="#0e0c08" stroke="#f0b31c" stroke-width="1"/>
          </svg>
        </div>
        <figcaption class="font-mono text-[.72rem] tracking-[.06em] text-ink-dim leading-normal mt-3.5">
          The hand-painted Khokhloma spoon this site's ornament is based on.
          <span class="fig-note block text-green-vine mt-1 text-[.68rem]">Photo coming soon.</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ── Contact (golden inversion) ────────────────────────────────────── -->
  <ContactPanel />

</Base>

<!-- Section rise-in: IntersectionObserver, threshold .12, fires once per section -->
<script>
  const io = new IntersectionObserver(
    entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.rise').forEach(el => io.observe(el));

  // Flip cards: tap to toggle on touch devices
  document.querySelectorAll('.role-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('flipped');
    });
  });
</script>

<style>
  /* ── Hero: vine-arrow draw sequence ────────────────────────────────────── */
  .rv-stem {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw 1s ease-out forwards;
  }
  .rv-stem--l { animation-delay: .6s; }
  .rv-stem--c { animation-delay: .6s; }
  .rv-stem--r { animation-delay: .6s; }
  .rv-tendril {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw .6s ease-out forwards 1.4s;
  }
  /* Mobile: cards stack, only show the centre stem */
  @media (max-width: 620px) {
    .rv-stem--l, .rv-stem--r,
    .rv-tendril { display: none; }
    .rv-berry circle:nth-child(1),
    .rv-berry circle:nth-child(2),
    .rv-berry circle:nth-child(5),
    .rv-berry circle:nth-child(6) { display: none; }
  }
  .rv-berry {
    opacity: 0;
    animation: bloom .4s ease forwards 1.7s;
  }

  /* ── Flip cards: hover/tap toggles the 3D rotation ─────────────────────── */
  .chip-inner {
    transition: transform .55s cubic-bezier(.4,0,.2,1);
  }
  .role-chip:hover .chip-inner,
  .role-chip.flipped .chip-inner {
    transform: rotateY(180deg);
  }

  /* Cross-component override: icons render at a fixed height inside the chip */
  .chip-front :global(.spoons),
  .chip-front :global(.chip-icon) {
    height: 88px;
    width: auto;
  }

  /* Tap hint: touch-only devices, hidden on hover-capable screens */
  .chip-tap { display: none; }
  @media (hover: none) {
    .chip-tap { display: block; }
    .role-chip.flipped .chip-tap { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .chip-inner { transition: none; }
  }

  /* ── Craft bullets: alternating crimson/gold dots ──────────────────────── */
  .craft .craft-li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 13px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-crimson);
  }
  .craft .craft-li:nth-child(even)::before { background: var(--color-gold); }
</style>
